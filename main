local function Notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title;
            Text = text;
            Duration = duration or 6;
        })
    end)
end

if Scripts[GameId] then
    Notify("Loading Script...", "GameID: "..GameId, 4)
    local success, result = pcall(function()
        loadstring(game:HttpGet(Scripts[GameId]))()
    end)
    if success then
        Notify("Script Loaded!", "Đã load script thành công!", 5)
    else
        Notify("Lỗi khi chạy script!", "Xem F9 để biết chi tiết", 8)
        warn("Lỗi Loadstring:", result)
    end
else
    Notify("Game chưa hỗ trợ!", "ID: "..tostring(GameId), 5)
    print("---------------------------------")
    warn("⚠️ Game chưa có trong danh sách!")
    print("Copy dòng này gửi admin: ["..GameId.."] = 'Link'")
    print("---------------------------------")
end

print("Current PlaceId:", GameId)
